# Rust
target/
**/*.rs.bk

# Whisper models (large binary files)
models/*.bin

# Build artifacts / packaged distributions
dist/
*.exe
*.dll
*.zip
*.pdb
*.log
panic.log

# OS
Thumbs.db
Desktop.ini
.DS_Store

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# Local agent / Claude state
.claude/

# Local agent-onboarding docs — kept private rather than published with
# the source. AGENTS.md is the engineering wiki an AI agent reads to
# get up to speed; DESIGN_BRIEF.md is the brief for visual-redesign
# work. Both are intentionally NOT part of the public repo.
AGENTS.md
DESIGN_BRIEF.md

# Environment / secrets (defense in depth — none should ever exist
# in the tree, but this keeps a stray `.env` from getting committed
# the moment one is created)
.env
.env.*
!.env.example
secrets.json
credentials.json

# Misc local fixtures / scratch files
*.wav
!apps/desktop/test_silence.wav
greendictatorcap.png
